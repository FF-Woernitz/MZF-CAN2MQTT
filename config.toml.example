[can-server]
host = "192.168.1.1"
port = 20001

[mqtt]
host         = "127.0.0.1"
port         = 1883
# client_id  = ""
username     = "user"
password     = "pass"
topic_prefix = "topic"

[influxdb]
url    = "http://127.0.0.1:8086"
token  = "my-influxdb-token"
org    = "my-org"
bucket = "can_data"

[label_maps.button_color]
"0x0" = "off"
"0x1" = "red"
"0x2" = "green"
"0x3" = "yellow"
"0x4" = "blue"
"0x5" = "violet"
"0x6" = "cyan"
"0x7" = "white"

[label_maps.switch_state]
"0x0" = "off"
"0x1" = "on"

[[messages]]
can_id   = 0xA006
name     = "keys_front_color"
mqtt     = true
influxdb = true

  [[messages.fields]]
  name       = "blaulicht"
  bit_offset = 0
  length     = 3
  label_map  = "button_color"

  [[messages.fields]]
