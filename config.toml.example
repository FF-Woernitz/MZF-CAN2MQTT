[[messages]]
can_id   = 0xF00A
name     = "battery"
mqtt     = true
influxdb = true

  [[messages.fields]]
  name       = "bord_spannung"
  byte       = 0
  type       = "int32"
  scale      = 0.1
  hysteresis = 0.2

  [[messages.fields]]
  name       = "bord_strom"
  byte       = 4
  type       = "int32"
  scale      = 0.01
  hysteresis = 0.2

[[messages]]
can_id   = 0xF00B
name     = "battery"
mqtt     = true
influxdb = true

  [[messages.fields]]
  name = "bord_percent"
  byte = 0
  type = "int32"

  [[messages.fields]]
  name       = "start_spannung2"
  byte       = 4
  type       = "int32"
  scale      = 0.1
  hysteresis = 0.2

[[messages]]
can_id   = 0xF00C
name     = "battery"
mqtt     = true
influxdb = true

  [[messages.fields]]
  name       = "start_strom"
  byte       = 0
  type       = "int32"
  scale      = 0.01
  hysteresis = 0.2

  [[messages.fields]]
  name = "start_percent"
  byte = 4
  type = "int32"